{
  "manifest_version": 3,
  "name": "BDM - Download Manager Integration",
  "short_name": "BDM",
  "version": "1.0.0",
  "description": "Intercept and send download requests to BDM (Blazing Download Manager) for macOS.",
  "author": "amirhp.com",
  "homepage_url": "https://github.com/amirhp-com/BDM-Safari-Extension",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "downloads",
    "tabs",
    "activeTab",
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
